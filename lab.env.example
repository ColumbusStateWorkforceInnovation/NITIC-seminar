# ============================================================
# ⚓ Admiral Bash's Island Adventure — Lab Configuration
# ============================================================
#
# INSTRUCTIONS:
#   Copy this file to lab.env and fill in your institution's values.
#   lab.env is gitignored — never commit it.
#
#   cp lab.env.example lab.env
#   # edit lab.env
#   just init
#
# ============================================================

# ── Required ─────────────────────────────────────────────────

# The LAN IP of the lab server (students will point /etc/hosts here)
SERVER_IP=192.168.X.X

# Rancher API token (generate from Rancher UI → Account → API Keys)
# Required for: just provision
RANCHER_TOKEN=token-xxxxx:yyyyyyyyyyyyyyyyy

# ── Lab Network ───────────────────────────────────────────────

# The domain used for all cluster services (must match k8s manifests)
# Students add this to /etc/hosts — no public DNS required.
LAB_DOMAIN=wagbiz.org

# Admin contact email for cert-manager ClusterIssuers (Let's Encrypt notifications)
# Change this to your institution's IT contact before deploying.
LAB_ADMIN_EMAIL=admin@wagbiz.org

# ── Server Access ─────────────────────────────────────────────

# SSH user on the lab server
SERVER_USER=ubuntu

# Path to SSH private key for server access
SERVER_SSH_KEY=~/.ssh/id_rsa

# ── Target Mode (local k3d vs. remote server) ─────────────────
# `just` auto-detects the target: LOCAL (k3d on this machine) when SERVER_IP
# is blank, REMOTE (SSH to the server) when SERVER_IP is set. The k3d test
# loop needs no flag — just `just bootstrap-k3d` then `just deploy-core`.
# Set LOCAL only to OVERRIDE the auto-detection:
#   LOCAL=1  — force local k3d even when SERVER_IP is set
#   LOCAL=0  — force remote even when SERVER_IP is blank
# Leave commented unless you need to override.
# LOCAL=1

# ── Organization Branding ────────────────────────────────────
# These populate the TLS certificate fields.
# Change to your institution's details when running your own seminar.

ORG_NAME="National Information Technology Innovation Center"
ORG_UNIT="ITIN Working Connections Fleet"
ORG_LOCALITY=Columbus
ORG_STATE=Ohio
ORG_COUNTRY=US

# ── Certificate ───────────────────────────────────────────────

# How many days the lab cert is valid.
# 20 days covers a typical Working Connections seminar + buffer.
CERT_DAYS=20

# ── AI Engine ─────────────────────────────────────────────────

# The Ollama model to serve via LiteLLM.
# Must be pulled after deploy: just pull-model
AI_MODEL=gemma3:4b

# The API key students use to hit the AI endpoint via aichat.
# Change this before the seminar for basic security.
AI_API_KEY=sk-nitic-admin

# ── Student Provisioning ──────────────────────────────────────

# Path to the student roster CSV (username,display_name,email)
STUDENT_ROSTER=scripts/students.csv

# Prefix for generated student passwords. Final: <PREFIX>-<username>
# Change this before distributing credential cards!
PASSWORD_PREFIX=AdmiralBash

# ── Client Bootstrap (setup-client.sh) ───────────────────────
# Optional. If your students are on headless VMs (no browser), pre-stage each
# kubeconfig on the docs server and template this URL into the credential
# card. setup-client.sh will curl it into ~/.kube/config automatically.
#
# Example:  https://docs.${LAB_DOMAIN}/creds/<username>.kubeconfig
# Leave commented to fall back to the Rancher-UI copy/paste flow.
#
# KUBECONFIG_URL_TEMPLATE=https://docs.${LAB_DOMAIN}/creds/__USERNAME__.kubeconfig

# ── K3s Version ───────────────────────────────────────────────
# Pins the k3s version for BOTH the local k3d test cluster and the remote
# server, so they run identical Kubernetes. Format: the k3s channel string
# — see https://github.com/k3s-io/k3s/releases (e.g. v1.35.5+k3s1).
# Blank = each tool's own default (NOT pinned; laptop and server may drift).
K3S_VERSION=v1.35.5+k3s1

# Set to 1 only if your VM image already ships Docker pre-installed.
# SKIP_DOCKER=1

# ── Let's Encrypt (Cloudflare DNS-01) ───────────────────────
# Optional: API token for Cloudflare DNS-01 validation (wildcard certs).
# Required only if you want trusted TLS instead of self-signed certs.
# Create at: Cloudflare Dashboard → My Profile → API Tokens → "Edit zone DNS"
# Then run: just deploy-cert-manager && just deploy-letsencrypt
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
