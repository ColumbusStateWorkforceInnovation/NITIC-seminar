    {
      "text": "You want to deploy an Nginx pod without typing 30 lines of YAML. What is the correct 'dry-run' command?",
      "image": null,
      "answer_time": 30000,
      "bonus_score_time": 15000,
      "scoring": {
        "min_score": 500,
        "max_score": 1000,
        "bonus_score": 200
      },
      "ty": "Single",
      "answers": [
        { "id": 9, "value": "kubectl generate pod nginx --image=nginx > pod.yaml", "correct": false },
        { "id": 10, "value": "kubectl run nginx --image=nginx --dry-run=client -o yaml > pod.yaml", "correct": true },
        { "id": 11, "value": "kubectl create pod nginx --dry-run=true > pod.yaml", "correct": false },
        { "id": 12, "value": "docker run nginx --export-yaml > pod.yaml", "correct": false }
      ]
    },
    {
