    {
      "text": "You built a custom web server image and want to run it in Kubernetes. Why does Kubernetes wrap your container inside a 'Pod'?",
      "image": null,
      "answer_time": 30000,
      "bonus_score_time": 15000,
      "scoring": {
        "min_score": 500,
        "max_score": 1000,
        "bonus_score": 200
