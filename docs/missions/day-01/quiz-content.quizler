      "ty": "Single",
      "answers": [
        { "id": 5, "value": "Because 'Pod' is a nautical term and Docker doesn't use it.", "correct": false },
        { "id": 6, "value": "A Pod allows multiple tightly-coupled containers to share the network.", "correct": true },
        { "id": 7, "value": "Pods automatically encrypt the container's traffic.", "correct": false },
        { "id": 8, "value": "Containers are not allowed to have IP addresses, only Pods are.", "correct": false }
      ]
