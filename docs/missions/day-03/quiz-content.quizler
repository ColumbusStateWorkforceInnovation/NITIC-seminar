      "ty": "Single",
      "answers": [
        { "id": 13, "value": "ArgoCD recreates it to match the Git state.", "correct": true },
        { "id": 14, "value": "It stays deleted — kubectl always wins.", "correct": false },
        { "id": 15, "value": "ArgoCD deletes the whole Git repository.", "correct": false },
        { "id": 16, "value": "The cluster shuts down for safety.", "correct": false }
