      "answers": [
        { "id": 1, "value": "It holds the adjustable knobs the templates read from.", "correct": true },
        { "id": 2, "value": "It is the log file of every helm install you have run.", "correct": false },
        { "id": 3, "value": "It stores the cluster's kubeconfig credentials.", "correct": false },
        { "id": 4, "value": "It is the compiled output Helm sends to the cluster.", "correct": false }
      ]
    },
    {
      "text": "You changed a value and want to roll it out to a running Helm release. Which command?",
      "image": null,
      "answer_time": 30000,
      "bonus_score_time": 15000,
      "scoring": {
        "min_score": 500,
        "max_score": 1000,
        "bonus_score": 200
      },
      "ty": "Single",
      "answers": [
        { "id": 5, "value": "helm reinstall <release>", "correct": false },
        { "id": 6, "value": "helm upgrade <release> ./<chart>", "correct": true },
        { "id": 7, "value": "kubectl apply -f values.yaml", "correct": false },
        { "id": 8, "value": "helm refresh <release>", "correct": false }
      ]
    },
    {
      "text": "GitOps has one commandment. What is the single source of truth?",
