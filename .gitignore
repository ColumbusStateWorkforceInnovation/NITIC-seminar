# Ignored temporary context files (including corporate certs)
temp-context/
.envrc

# Institution-specific lab config (copy from lab.env.example and fill in)
lab.env

# Harbor push-robot creds — written by `just bootstrap-harbor`, staged for the
# setup-client.sh fetch path. A push-only token, but never commit it.
harbor-robot.env

# Student roster — holds real names + emails (PII). Copy from
# students.csv.example and fill in. Never commit to a public repo.
scripts/students.csv

# Dex SSO roster — the live class file holds real names + emails (PII). Copy
# from dex.yaml.example (pirate placeholders) and fill in. Never commit.
k8s/core-tools/dex.yaml

# Project-local kubeconfig — written by `just bootstrap-k3d`; holds k3d
# cluster admin credentials. Never commit.
.kube/

# Pinned target marker — written by `just use-local` / `use-remote`.
.just-target

# Lab TLS Private Keys
# DO NOT commit private keys — distribute to server via scp (see certs/README.md)
# Public certs (ca.crt, tls.crt) ARE committed — students need them to trust the CA.
certs/*.key
certs/*.srl

# Rendered slide decks now build into docs/slides/ (committed, so the MkDocs
# pod serves them on the site via git-sync). Deck SOURCES live in slides/**/*.md,
# slides/themes/, slides/.marprc.yml. The old slides/build/ path stays ignored in
# case a local `just slides` from before this change left artifacts behind.
slides/build/

# macOS artifacts
.DS_Store
**/.DS_Store

# OpenTofu — terraform/ (uss-nitic Azure VM)
# .terraform.lock.hcl IS committed (pins provider versions); state/keys are not.
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/crash.log
terraform/terraform.tfvars
terraform/.ssh/
.claude/settings.local.json
scripts/.claude/settings.local.json